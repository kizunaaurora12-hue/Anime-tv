<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/color_surface"
    android:padding="24dp">

    <!-- Logo -->
    <ImageView android:layout_width="72dp" android:layout_height="72dp"
        android:src="@drawable/ic_launcher_foreground"
        android:layout_marginBottom="12dp"/>

    <TextView android:id="@+id/text_version"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/color_primary"
        android:textSize="14sp" android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/app_tagline"
        android:textColor="@color/color_text_secondary"
        android:textSize="10sp"
        android:layout_marginBottom="16dp"/>

    <View android:layout_width="60dp" android:layout_height="1dp"
        android:background="@color/color_divider"
        android:layout_marginBottom="16dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/thanks_to"
        android:textColor="@color/color_text_dim"
        android:textSize="9sp" android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView android:id="@+id/text_users"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/color_text_secondary"
        android:textSize="11sp" android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- Buttons -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/button_website"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="@string/button_website"
            android:textColor="@color/color_text"
            android:background="@drawable/button_rounded_background"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/button_telegram"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="@string/button_telegram"
            android:textColor="@color/color_text"
            android:background="@drawable/corner_right"
            android:paddingStart="16dp" android:paddingEnd="16dp"/>
    </LinearLayout>
</LinearLayout>