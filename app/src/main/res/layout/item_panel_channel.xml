<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_ch_root"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:focusable="true"
    android:clickable="true">

    <!-- Logo / inisial -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/channel_logo_bg"
        android:layout_marginEnd="10dp">
        <ImageView
            android:id="@+id/panel_ch_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:padding="3dp"/>
        <TextView
            android:id="@+id/panel_ch_initial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@color/color_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Nama -->
    <TextView
        android:id="@+id/panel_ch_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/color_text"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- DRM badge -->
    <TextView
        android:id="@+id/panel_ch_drm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DRM"
        android:textSize="7sp"
        android:textColor="@color/color_primary"
        android:background="@drawable/drm_badge_bg"
        android:paddingStart="4dp" android:paddingEnd="4dp"
        android:paddingTop="1dp" android:paddingBottom="1dp"
        android:visibility="gone"/>

</LinearLayout>
