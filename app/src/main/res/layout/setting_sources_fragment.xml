<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data>
        <variable name="sourcesAdapter" type="com.miyuki.tv.adapter.SourcesAdapter"/>
    </data>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/color_surface"
        android:padding="12dp">

        <!-- Add URL row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <EditText android:id="@+id/input_source"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="@string/input_url"
                android:textColor="@color/color_text"
                android:textColorHint="@color/color_text_dim"
                android:textSize="12sp"
                android:background="@drawable/search_bg"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:inputType="textUri"
                android:imeOptions="actionDone"
                android:singleLine="true"/>

            <ImageButton android:id="@+id/btn_add"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/button_rounded_background"
                android:src="@drawable/ic_add_url"
                android:padding="8dp"
                android:layout_marginStart="6dp"/>

            <ImageButton android:id="@+id/btn_pick"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/button_rounded_background"
                android:src="@drawable/ic_pick_file"
                android:padding="8dp"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sources"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adapter="@{sourcesAdapter}"/>
    </LinearLayout>
</layout>