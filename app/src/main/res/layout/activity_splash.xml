<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_bg">

    <!-- Radial glow top-right -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|end"
        android:background="@drawable/splash_bg"
        android:alpha="0.4"/>

    <!-- Center content -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Logo circle -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="20dp">
            <View
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/user_avatar_bg"/>
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher_foreground"
                android:scaleType="fitCenter"/>
        </FrameLayout>

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/color_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            android:textColor="@color/color_text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp"/>

        <!-- Status text -->
        <TextView
            android:id="@+id/text_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_preparing_playlist"
            android:textColor="@color/color_text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="12dp"/>

        <!-- Loading bar track -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="3dp"
            android:background="@drawable/bar_track">
            <View
                android:id="@+id/loading_bar"
                android:layout_width="0dp"
                android:layout_height="3dp"
                android:background="@drawable/bar_fill"/>
        </FrameLayout>

    </LinearLayout>

    <!-- Bottom: contributors -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_presents"
            android:textColor="@color/color_text_dim"
            android:textSize="9sp"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/text_users"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_text_secondary"
            android:textSize="10sp"/>

    </LinearLayout>

</FrameLayout>
