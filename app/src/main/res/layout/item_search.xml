<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="6dp"
    android:layout_margin="3dp"
    android:background="@drawable/channel_card_bg"
    android:focusable="true"
    android:clickable="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/channel_logo_bg"
        android:layout_marginBottom="4dp">
        <ImageView android:id="@+id/search_img_logo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:padding="4dp"/>
        <TextView android:id="@+id/search_txt_logo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@color/color_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"/>
    </FrameLayout>

    <TextView android:id="@+id/search_txt_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/color_text"
        android:textSize="9sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:gravity="center_horizontal"/>
</LinearLayout>