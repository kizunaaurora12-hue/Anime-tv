<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sidebar_item_root"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="4dp"
    android:paddingEnd="8dp"
    android:layout_marginBottom="2dp"
    android:focusable="true"
    android:clickable="true">

    <View android:id="@+id/sidebar_accent"
        android:layout_width="3dp" android:layout_height="18dp"
        android:background="@drawable/sidebar_accent"
        android:layout_marginEnd="8dp"
        android:visibility="invisible"/>

    <TextView android:id="@+id/sidebar_icon"
        android:layout_width="30dp" android:layout_height="20dp"
        android:gravity="center"
        android:textColor="#50E83D7A"
        android:textSize="7sp" android:textStyle="bold"
        android:background="@drawable/sidebar_count_badge"
        android:layout_marginEnd="8dp"/>

    <TextView android:id="@+id/sidebar_name"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/color_text_secondary"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView android:id="@+id/sidebar_count"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#50E83D7A"
        android:textSize="8sp"
        android:background="@drawable/sidebar_count_badge"
        android:paddingStart="4dp" android:paddingEnd="4dp"
        android:paddingTop="1dp" android:paddingBottom="1dp"/>
</LinearLayout>